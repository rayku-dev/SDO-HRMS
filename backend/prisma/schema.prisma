generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  APPROVING_AUTHORITY
  HR_ASSOCIATE
  HR_HEAD
  UNIT_HEAD
  EMPLOYEE
  SCHOOL_PERSONNEL
}

// Account model - base auth layer
model Account {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(EMPLOYEE)
  isActive           Boolean  @default(true) @map("is_active")
  hasChangedPassword Boolean  @default(false) @map("has_changed_password")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  sessions      Session[]
  pds           Pds?
  user          User?
  files201      File201[]

  @@map("accounts")
}

// User Profile - Merged from StaffData and SchoolPersonnelData
model User {
  id        String  @id @default(uuid())
  accountId String  @unique @map("account_id")
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  firstName  String? @map("first_name")
  lastName   String? @map("last_name")
  middleName String? @map("middle_name")
  nameExtension     String? @map("name_extension")

  // Government Identifiers
  gsisId       String? @map("gsis_number")
  pagibigId    String? @map("pagibig_number")
  philhealthId String? @map("philhealth_number")
  sssId        String? @map("sss_number")
  tinId        String? @map("tin_number")

  // Addresses
  residentialAddress Json? @map("residential_address")
  permanentAddress   Json? @map("permanent_address")

  // Contact
  phoneNumber     String? @map("phone_number")
  telephoneNumber String? @map("telephone_number")

  // Station and Assignment SDO
  jobTitle       String? @map("job_title")
  unit           String? @map("unit")
  hrHead         String? @map("hr_head")
  supervisor     String? @map("supervisor")
  approver       String? @map("approver")
  schedule       String? @map("schedule")
  employeeNumber String? @unique @map("employee_number")

  // Station and Assignment School
  designation     String? // SDO || School
  appointment     String? // JO, Nation, Casual
  appointmentDate DateTime? @map("appointment_date")

  // Signing
  signature String?
  initial   String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// File 201 - 201 file management
model File201 {
  id        String  @id @default(uuid())
  accountId String  @map("account_id")
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  fileName    String  @map("file_name")
  filePath    String  @map("file_path")
  fileSize    Int     @map("file_size")
  mimeType    String  @map("mime_type")
  category    String? // Keep for legacy compatibility
  description String?

  // New relation
  categoryId   String?       @map("category_id")
  fileCategory FileCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  uploadedBy String?  @map("uploaded_by")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  @@index([accountId])
  @@index([category])
  @@index([categoryId])
  @@map("files_201")
}

model FileCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  files File201[]

  @@map("file_categories")
}

// Layer 2: Refresh Tokens (long-lived, stored in DB for revocation)
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique @map("token")
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")

  account Account @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// Layer 3: Sessions (server-side session tracking for extra security)
model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  sessionToken String   @unique @map("session_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  userAgent    String?  @map("user_agent")
  ipAddress    String?  @map("ip_address")
  isActive     Boolean  @default(true) @map("is_active")

  account Account @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
  @@index([expiresAt])
  @@map("sessions")
}

model Pds {
  id                   String   @id @default(uuid())
  userId               String   @unique @map("user_id")
  account              Account  @relation(fields: [userId], references: [id], onDelete: Cascade)
  personalData         Json     @map("personal_data")
  familyData           Json     @map("family_data")
  educationalData      Json     @map("educational_data")
  civilServiceData     Json?    @map("civil_service_data")
  workExperienceData   Json?    @map("work_experience_data")
  voluntaryWorkData    Json?    @map("voluntary_work_data")
  trainingProgramsData Json?    @map("training_programs_data")
  otherInfo            Json?    @map("other_info")
  lastpData            Json?    @map("lastp_data")
  status               String   @default("draft")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@map("pds")
}
